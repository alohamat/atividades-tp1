<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TechStore - Produtos</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/style.css">
</head>
<body>
   <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container">
        <a class="navbar-brand" href="/">TechStore</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav ms-auto">
                <li class="nav-item">
                    <a class="nav-link" href="/">Início</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="/produtos">Produtos</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="/contato">Contato</a>
                </li>
            </ul>
        </div>
    </div>
</nav>

    <div class="container my-5">
        <h1 class="text-center mb-4">Nossos Produtos</h1>
        
        <div class="row mb-4">
            <div class="col-md-6">
                <div class="input-group">
                    <input type="text" class="form-control" placeholder="Buscar produtos...">
                    <button class="btn btn-custom" type="button">Buscar</button>
                </div>
            </div>
            <div class="col-md-6">
                <select class="form-select">
                    <option selected>Ordenar por:</option>
                    <option value="1">Menor preço</option>
                    <option value="2">Maior preço</option>
                    <option value="3">Mais vendidos</option>
                </select>
            </div>
        </div>

        <div class="row">
            <div class="col-md-4 mb-4">
                <div class="card">
                    <img src="https://images.unsplash.com/photo-1517336714731-489689fd1ca8?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&q=80" class="card-img-top product-image" alt="Tablet">
                    <div class="card-body">
                        <h5 class="card-title">Tablet Pro</h5>
                        <p class="card-text">Tablet com tela de alta resolução.</p>
                        <span class="badge bg-success">R$ 1.899,00</span>
                        <a href="/detalhes" class="btn btn-custom mt-2">Ver Detalhes</a>
                    </div>
                </div>
            </div>
            <div class="col-md-4 mb-4">
                <div class="card">
                    <img src="https://images.unsplash.com/photo-1586950012036-b957f2c7cbf3?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&q=80" class="card-img-top product-image" alt="Fones de ouvido">
                    <div class="card-body">
                        <h5 class="card-title">Fones Bluetooth</h5>
                        <p class="card-text">Cancelamento de ruído ativo.</p>
                        <span class="badge bg-success">R$ 499,00</span>
                        <a href="/detalhes" class="btn btn-custom mt-2">Ver Detalhes</a>
                    </div>
                </div>
            </div>
            <div class="col-md-4 mb-4">
                <div class="card">
                    <img src="https://images.unsplash.com/photo-1526170375885-4d8ecf77b99f?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&q=80" class="card-img-top product-image" alt="Câmera">
                    <div class="card-body">
                        <h5 class="card-title">Câmera DSLR</h5>
                        <p class="card-text">Câmera profissional 24MP.</p>
                        <span class="badge bg-success">R$ 3.299,00</span>
                        <a href="/detalhes" class="btn btn-custom mt-2">Ver Detalhes</a>
                    </div>
                </div>
            </div>
        </div>

        <nav aria-label="Navegação de página">
            <ul class="pagination justify-content-center">
                <li class="page-item disabled">
                    <a class="page-link" href="#" tabindex="-1">Anterior</a>
                </li>
                <li class="page-item active"><a class="page-link" href="#">1</a></li>
                <li class="page-item"><a class="page-link" href="#">2</a></li>
                <li class="page-item"><a class="page-link" href="#">3</a></li>
                <li class="page-item">
                    <a class="page-link" href="#">Próxima</a>
                </li>
            </ul>
        </nav>
    </div>

    <footer class="footer text-center">
        <div class="container">
            <p>&copy; 2023 TechStore. Todos os direitos reservados.</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>